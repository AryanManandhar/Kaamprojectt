# Copy this file to .env and fill in your real values.
# Never commit the real .env file to git.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=kam_app
DB_PORT=3306

# Used to sign login session tokens — make this a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Port the API server runs on
PORT=4000
